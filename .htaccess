# ================================
# 🔒 SEGURANÇA
# ================================

<FilesMatch "^(config|send|deploy|setup-security)\.php$">
    Require all denied
</FilesMatch>

<FilesMatch "^(credentials-local|deploy-config)\.(php|example\.php)$">
    Require all denied
</FilesMatch>

<Files "composer.json">
    Require all denied
</Files>

<Files "mail-config.php">
    Require all denied
</Files>

<FilesMatch "\.(log|bak)$">
    Require all denied
</FilesMatch>

# ================================
# ⚙️ REWRITE ENGINE
# ================================

<IfModule mod_rewrite.c>
RewriteEngine On

# ================================
# 🌐 FORÇAR HTTPS + WWW (PADRÃO ÚNICO)
# ================================

RewriteCond %{HTTPS} off [OR]
RewriteCond %{HTTP_HOST} !^www\. [NC]
RewriteRule ^(.*)$ https://www.santscompany.com/$1 [R=301,L]

# ================================
# 🚫 BLOQUEIO PHP SENSÍVEL
# ================================

RewriteRule ^server/contact\.php$ - [L]
RewriteRule ^server/.+\.php$ - [F,L]
RewriteRule ^scripts/.+\.php$ - [F,L]

# ================================
# 🔥 REMOVER INDEX.HTML (QUALQUER PASTA)
# ================================

RewriteCond %{THE_REQUEST} /index\.html [NC]
RewriteRule ^(.*)index\.html$ /$1 [R=301,L]

# ================================
# 🔗 REMOVER .HTML DA URL (REDIRECT EXTERNO)
# ================================

RewriteCond %{THE_REQUEST} ^[A-Z]{3,}\s([^.]+)\.html [NC]
RewriteRule ^ %1 [R=301,L]

# ================================
# ✨ URL LIMPA (FUNCIONAMENTO INTERNO)
# ================================

# Se não for arquivo ou pasta real
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d

# Se existir .html correspondente
RewriteCond %{REQUEST_FILENAME}.html -f
RewriteRule ^(.*)$ $1.html [L]

# ================================
# 📂 SUPORTE AUTOMÁTICO A PASTAS (index.html)
# ================================

RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{REQUEST_FILENAME}/index.html -f
RewriteRule ^(.*)$ $1/index.html [L]

</IfModule>

# ================================
# ⚡ CACHE (PERFORMANCE)
# ================================

<IfModule mod_expires.c>
ExpiresActive On

# Imagens
ExpiresByType image/jpg "access 1 year"
ExpiresByType image/jpeg "access 1 year"
ExpiresByType image/png "access 1 year"
ExpiresByType image/webp "access 1 year"
ExpiresByType image/svg+xml "access 1 year"

# CSS e JS
ExpiresByType text/css "access 1 month"
ExpiresByType application/javascript "access 1 month"

# HTML (curto, pra atualizar rápido)
ExpiresByType text/html "access 5 minutes"

ExpiresDefault "access 7 days"
</IfModule>

# ================================
# 🚀 COMPRESSÃO GZIP
# ================================

<IfModule mod_deflate.c>
AddOutputFilterByType DEFLATE text/html text/plain text/css application/javascript application/json
</IfModule>

# ================================
# 🔐 HEADERS DE SEGURANÇA + PERFORMANCE
# ================================

<IfModule mod_headers.c>
Header set X-Content-Type-Options "nosniff"
Header set X-Frame-Options "SAMEORIGIN"
Header set X-XSS-Protection "1; mode=block"
Header set Referrer-Policy "strict-origin-when-cross-origin"
</IfModule>